{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_GA_ID": {
      "description": "Google Analytics ID"
    }
  },
  "redirects": [
    {
      "source": "/privacy",
      "destination": "/legal/privacy",
      "permanent": true
    },
    {
      "source": "/terms",
      "destination": "/legal/terms",
      "permanent": true
    }
  ]
}
