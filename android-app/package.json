{
  "name": "peitho",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "start": "react-native start",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "clean": "cd android && ./gradlew clean && cd ..",
    "build:release": "cd android && ./gradlew assembleRelease",
    "web": "webpack serve --config webpack.config.js --mode development --port 8080",
    "web:build": "webpack --config webpack.config.js --mode production"
  },
  "dependencies": {
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-native-firebase/analytics": "^20.5.0",
    "@react-native-firebase/app": "^20.5.0",
    "@react-native-firebase/auth": "^20.5.0",
    "@react-native-firebase/firestore": "^20.5.0",
    "@react-native-firebase/messaging": "^20.5.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "ajv": "^8.20.0",
    "babel-loader": "^10.1.1",
    "babel-plugin-react-native-web": "^0.21.2",
    "date-fns": "^3.6.0",
    "html-webpack-plugin": "^5.6.7",
    "react": "18.3.1",
    "react-dom": "^19.2.7",
    "react-native": "0.75.4",
    "react-native-gesture-handler": "^2.19.0",
    "react-native-haptic-feedback": "^2.3.3",
    "react-native-iap": "^12.15.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "^3.15.0",
    "react-native-safe-area-context": "^4.11.0",
    "react-native-screens": "^3.34.0",
    "react-native-svg": "^15.7.1",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.2",
    "uuid": "^10.0.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "0.75.4",
    "@react-native/eslint-config": "0.75.4",
    "@react-native/metro-config": "0.75.4",
    "@react-native/typescript-config": "0.75.4",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.7.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@types/react-native": "^0.73.0",
    "@types/uuid": "^10.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "react-test-renderer": "18.3.1",
    "ts-jest": "^29.2.0",
    "typescript": "5.5.4"
  },
  "jest": {
    "preset": "react-native",
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "setupFiles": [
      "./__tests__/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "setup.ts"
    ]
  }
}
